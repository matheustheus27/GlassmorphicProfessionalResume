FROM node:22-slim

# Installs the dependencies required for the stable operation of headless Puppeteer on Linux
RUN apt-get update && apt-get install -y \
    chromium \
    fonts-ipafont-gothic \
    fonts-wqy-zenhei \
    fonts-thai-tlwg \
    fonts-kacst \
    fonts-freefont-ttf \
    libxss1 \
    --no-install-recommends \
    && rm -rf /var/lib/apt/lists/*

WORKDIR /app

COPY package*.json ./

# 🌟 SCOPE PRIVILEGE CONCEPT: Sets the global environment variable in the container
ENV PUPPETEER_SKIP_DOWNLOAD=true

# Installs local dependencies and nodemon globally for Node server hot reload
RUN npm install && npm install -g nodemon

COPY . .

EXPOSE 3001

# Starts the server, which monitors file changes in real time
CMD ["nodemon", "server.js"]